# Supabase Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://your-supabase-url.supabase.co:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your-db-password

# Google OAuth2 Credentials
# Get these from Google Cloud Console (APIs & Services > Credentials)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# SendGrid Email Configuration
# Get your API key from SendGrid dashboard
SENDGRID_API_KEY=your-sendgrid-api-key
VERIFIED_SENDER_EMAIL=your-verified-email@example.com

# JWT Security
# Generate a long random string for production
JWT_SECRET=your-secure-jwt-secret-key-at-least-32-chars
